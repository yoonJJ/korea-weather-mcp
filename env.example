# 공공데이터포털에서 발급한 기상청(단기예보) 서비스키
KMA_SERVICE_KEY=

# HTTP MCP (`python -m weather_mcp.apps.http`). Claude 원격 MCP는 보통 https 공개 URL 필요
PORT=3000
MCP_HOST=127.0.0.1

# `python -m weather_mcp.apps.agent_loop` — Anthropic Messages API (MCP 없이 tools 직접 등록)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
